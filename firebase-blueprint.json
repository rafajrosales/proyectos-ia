{
  "entities": {
    "UserConfig": {
      "title": "UserConfig",
      "description": "Configuration settings for the user's laser quoting system.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's ID."
        },
        "inversion": {
          "type": "number",
          "description": "Initial investment in equipment."
        },
        "vidaUtil": {
          "type": "number",
          "description": "Useful life of equipment in years."
        },
        "renta": {
          "type": "number",
          "description": "Monthly rent."
        },
        "sueldoSemanal": {
          "type": "number",
          "description": "Weekly operator salary."
        },
        "internet": {
          "type": "number",
          "description": "Monthly internet cost."
        },
        "mantenimientoAnual": {
          "type": "number",
          "description": "Annual maintenance cost."
        },
        "kwh": {
          "type": "number",
          "description": "Cost per kWh."
        },
        "horasMes": {
          "type": "number",
          "description": "Productive hours per month."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp."
        }
      },
      "required": ["uid", "inversion", "vidaUtil", "renta", "sueldoSemanal", "internet", "mantenimientoAnual", "kwh", "horasMes"]
    },
    "Quote": {
      "title": "Quote",
      "description": "A saved quote generated by the user.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's ID who created the quote."
        },
        "fecha": {
          "type": "string",
          "format": "date-time",
          "description": "Creation date of the quote."
        },
        "cliente": {
          "type": "string",
          "description": "Client name."
        },
        "material": {
          "type": "string",
          "description": "Material name."
        },
        "lienzo": {
          "type": "string",
          "description": "Canvas dimensions."
        },
        "total": {
          "type": "number",
          "description": "Total cost."
        },
        "datos": {
          "type": "string",
          "description": "JSON stringified detailed quote data."
        }
      },
      "required": ["uid", "fecha", "cliente", "material", "lienzo", "total", "datos"]
    }
  },
  "firestore": {
    "/users/{userId}/config/current": {
      "schema": {
        "$ref": "#/entities/UserConfig"
      },
      "description": "The user's current configuration."
    },
    "/users/{userId}/quotes/{quoteId}": {
      "schema": {
        "$ref": "#/entities/Quote"
      },
      "description": "The user's saved quotes."
    }
  }
}
