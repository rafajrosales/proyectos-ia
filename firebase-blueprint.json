{
  "entities": {
    "UserConfig": {
      "title": "UserConfig",
      "description": "Configuration settings for the user's laser quoting system.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's ID."
        },
        "inversion": {
          "type": "number",
          "description": "Initial investment in equipment."
        },
        "vidaUtil": {
          "type": "number",
          "description": "Useful life of equipment in years."
        },
        "renta": {
          "type": "number",
          "description": "Monthly rent."
        },
        "sueldoSemanal": {
          "type": "number",
          "description": "Weekly operator salary."
        },
        "internet": {
          "type": "number",
          "description": "Monthly internet cost."
        },
        "mantenimientoAnual": {
          "type": "number",
          "description": "Annual maintenance cost."
        },
        "kwh": {
          "type": "number",
          "description": "Cost per kWh."
        },
        "horasMes": {
          "type": "number",
          "description": "Productive hours per month."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp."
        }
      },
      "required": ["uid", "inversion", "vidaUtil", "renta", "sueldoSemanal", "internet", "mantenimientoAnual", "kwh", "horasMes"]
    },
    "Quote": {
      "title": "Quote",
      "description": "A saved quote generated by the user.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's ID who created the quote."
        },
        "fecha": {
          "type": "string",
          "format": "date-time",
          "description": "Creation date of the quote."
        },
        "cliente": {
          "type": "string",
          "description": "Article name."
        },
        "clienteId": {
          "type": "string",
          "description": "Reference to the customer (optional)."
        },
        "clienteNombre": {
          "type": "string",
          "description": "Customer name (optional)."
        },
        "material": {
          "type": "string",
          "description": "Material name."
        },
        "lienzo": {
          "type": "string",
          "description": "Canvas dimensions."
        },
        "total": {
          "type": "number",
          "description": "Total cost."
        },
        "datos": {
          "type": "string",
          "description": "JSON stringified detailed quote data."
        }
      },
      "required": ["uid", "fecha", "cliente", "material", "lienzo", "total", "datos"]
    },
    "Cliente": {
      "title": "Cliente",
      "description": "Customer contact information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's ID who owns the customer."
        },
        "nombre": {
          "type": "string",
          "description": "Full name of the customer."
        },
        "telefono": {
          "type": "string",
          "description": "Phone number."
        },
        "email": {
          "type": "string",
          "description": "Email address."
        },
        "empresa": {
          "type": "string",
          "description": "Company name."
        },
        "notas": {
          "type": "string",
          "description": "Internal notes."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation date."
        }
      },
      "required": ["uid", "nombre", "createdAt"]
    },
    "Pedido": {
      "title": "Pedido",
      "description": "An order created from a quote.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's ID who owns the order."
        },
        "fecha": {
          "type": "string",
          "format": "date-time",
          "description": "Order creation date."
        },
        "clienteId": {
          "type": "string",
          "description": "Reference to the customer."
        },
        "clienteNombre": {
          "type": "string",
          "description": "Customer name at the time of order."
        },
        "quoteId": {
          "type": "string",
          "description": "Reference to the original quote."
        },
        "articuloNombre": {
          "type": "string",
          "description": "Name of the item being produced."
        },
        "total": {
          "type": "number",
          "description": "Total order value."
        },
        "status": {
          "type": "string",
          "enum": ["Pendiente", "En Proceso", "Listo para Entrega", "Entregado", "Pagado", "Cancelado"],
          "description": "Current order status."
        },
        "fechaEntrega": {
          "type": "string",
          "format": "date",
          "description": "Expected delivery date."
        },
        "notas": {
          "type": "string",
          "description": "Order specific notes."
        },
        "datosQuote": {
          "type": "string",
          "description": "JSON stringified detailed quote data."
        }
      },
      "required": ["uid", "fecha", "clienteId", "clienteNombre", "articuloNombre", "total", "status", "datosQuote"]
    }
  },
  "firestore": {
    "/users/{userId}/config/current": {
      "schema": {
        "$ref": "#/entities/UserConfig"
      },
      "description": "The user's current configuration."
    },
    "/users/{userId}/quotes/{quoteId}": {
      "schema": {
        "$ref": "#/entities/Quote"
      },
      "description": "The user's saved quotes."
    },
    "/users/{userId}/clientes/{clienteId}": {
      "schema": {
        "$ref": "#/entities/Cliente"
      },
      "description": "The user's customers."
    },
    "/users/{userId}/pedidos/{pedidoId}": {
      "schema": {
        "$ref": "#/entities/Pedido"
      },
      "description": "The user's orders."
    }
  }
}
